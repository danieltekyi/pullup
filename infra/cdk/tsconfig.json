{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./",
    "rootDir": "./",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "declaration": false,
    "sourceMap": true,
    "types": ["node"],
    "lib": ["ES2022"],
    "isolatedModules": false,
    "composite": false,
    "noEmit": false
  },
  "include": ["bin/**/*", "lib/**/*"],
  "exclude": ["cdk.out", "node_modules"]
}
