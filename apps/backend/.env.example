# Backend env — copy to .env and fill in.
# CRITICAL: do NOT commit the filled version.

NODE_ENV=development
PORT=3000
LOG_LEVEL=info

AWS_REGION=us-east-1

# Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxx

# DynamoDB table names (override per environment)
TABLE_ORDERS=pullup-dev-orders
TABLE_ORDER_EVENTS=pullup-dev-order-events
TABLE_RIDERS=pullup-dev-riders
TABLE_FLEET=pullup-dev-fleet
TABLE_PARTNERS=pullup-dev-partners
TABLE_EXPENDITURES=pullup-dev-expenditures
TABLE_USERS=pullup-dev-users
TABLE_BRANCHES=pullup-dev-branches
TABLE_PERMISSIONS=pullup-dev-permissions
TABLE_PARAMS=pullup-dev-params
TABLE_ZONES=pullup-dev-zones
TABLE_ZONE_RATES=pullup-dev-zone-rates
TABLE_CUSTOMERS=pullup-dev-customers
TABLE_PUSH_SUBS=pullup-dev-push-subs

BUCKET_PROOF=pullup-dev-proof

# Tracker links — must be at least 32 chars
TRACKER_LINK_SECRET=change-me-to-a-64-char-random-string

FRONTEND_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Optional GPS tracker API
TRACKER_API_URL=
TRACKER_API_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@pullup.app

# Africa's Talking (SMS)
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@pullup.app

# Sentry (optional)
SENTRY_DSN=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
RATE_LIMIT_TRACKER_MAX=10

# Maps
GOOGLE_MAPS_API_KEY=

# M-Pesa (rider payouts)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
