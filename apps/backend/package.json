{
  "name": "@pullup/backend",
  "version": "2.0.0",
  "private": true,
  "description": "PullUp backend — Express + AWS Lambda, DynamoDB, Cognito, S3, WAF-ready",
  "main": "dist/handler.js",
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/local.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "npm run build && node ../../scripts/zip-lambda.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.616.0",
    "@aws-sdk/client-dynamodb": "^3.616.0",
    "@aws-sdk/client-s3": "^3.616.0",
    "@aws-sdk/client-secrets-manager": "^3.616.0",
    "@aws-sdk/lib-dynamodb": "^3.616.0",
    "@aws-sdk/s3-request-presigner": "^3.616.0",
    "@pullup/shared": "2.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.14",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "serverless-http": "^3.2.0",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.11",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
