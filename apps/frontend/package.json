{
  "name": "@pullup/frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "cross-env VITE_APP_MODE=admin vite",
    "dev:rider": "cross-env VITE_APP_MODE=rider vite",
    "dev:customer": "cross-env VITE_APP_MODE=customer vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:admin": "cross-env VITE_APP_MODE=admin vite build",
    "build:rider": "cross-env VITE_APP_MODE=rider vite build",
    "build:customer": "cross-env VITE_APP_MODE=customer vite build",
    "build:all": "npm run build:admin && npm run build:rider && npm run build:customer",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@pullup/shared": "2.0.0",
    "@sentry/react": "^8.20.0",
    "@tanstack/react-query": "^5.51.11",
    "axios": "^1.7.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "idb": "^8.0.0",
    "lucide-react": "^0.408.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.1",
    "react-signature-canvas": "^1.0.6",
    "recharts": "^2.12.7",
    "tailwind-merge": "^2.4.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-signature-canvas": "^1.0.6",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "cross-env": "^7.0.3",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.4",
    "vite": "^5.3.4",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.0.5",
    "workbox-window": "^7.1.0"
  }
}
